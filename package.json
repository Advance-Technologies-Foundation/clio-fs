{
  "name": "clio-fs",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "corepack pnpm -r build",
    "check": "corepack pnpm -r check",
    "client-ui": "node scripts/dev-client-ui.mjs",
    "dev": "node scripts/dev.mjs",
    "release:artifacts": "node scripts/build-release-artifacts.mjs",
    "server": "node scripts/dev-server.mjs",
    "scenario:local-sync": "node scripts/run-local-sync-scenario.mjs",
    "test": "corepack pnpm -r test && node --test scripts/*.test.mjs",
    "format": "corepack pnpm -r format"
  }
}
