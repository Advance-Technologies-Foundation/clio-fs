{
  "name": "@clio-fs/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": "./src/index.ts",
  "bin": {
    "clio-fs-server": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "node ../../scripts/dev-compiled.mjs",
    "test": "corepack pnpm build && node --test dist/**/*.test.js",
    "format": "node -e \"console.log('No formatter configured for @clio-fs/server yet')\""
  },
  "dependencies": {
    "@clio-fs/config": "workspace:*",
    "@clio-fs/contracts": "workspace:*",
    "@clio-fs/database": "workspace:*",
    "@clio-fs/server-ui": "workspace:*",
    "@clio-fs/sync-core": "workspace:*"
  }
}
