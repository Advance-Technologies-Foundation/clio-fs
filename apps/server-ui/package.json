{
  "name": "@clio-fs/server-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "node ../../scripts/dev-compiled.mjs",
    "test": "corepack pnpm build && node --test dist/**/*.test.js",
    "format": "node -e \"console.log('No formatter configured for @clio-fs/server-ui yet')\""
  },
  "dependencies": {
    "@clio-fs/config": "workspace:*",
    "@clio-fs/contracts": "workspace:*",
    "@clio-fs/ui-kit": "workspace:*"
  }
}
